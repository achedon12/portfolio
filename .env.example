DOCKER_HTTP_PORT=80

# =============================================================
# Engagement — likes/views anonymes
# =============================================================
# Pepper utilisé pour hasher les IPs (RGPD : on ne stocke jamais l'IP brute).
# Doit être stable une fois en prod, sinon les "déjà liké" deviennent caduques.
# via openssl rand -base64 32
IP_HASH_PEPPER=

