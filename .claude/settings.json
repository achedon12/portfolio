{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run dev*)",
      "Bash(npm run build)",
      "Bash(npm start)",
      "Bash(npm run db:migrate*)",
      "Bash(npm run db:deploy)",
      "Bash(npm run db:status)",
      "Bash(npm run db:generate)",
      "Bash(npm run db:studio)",
      "Bash(npm run db:seed)",
      "Bash(npm install*)",
      "Bash(npx tsc --noEmit*)",
      "Bash(npx eslint*)",
      "Bash(npx next build*)",
      "Bash(npx next dev*)",
      "Bash(npx prisma generate*)",
      "Bash(npx prisma migrate dev*)",
      "Bash(npx prisma migrate status*)",
      "Bash(npx prisma migrate deploy*)",
      "Bash(npx prisma studio*)",
      "Bash(npx prisma validate*)",
      "Bash(npx prisma --version)",
      "Bash(node -e *)",
      "Bash(openssl rand*)",
      "Bash(docker compose ps)",
      "Bash(docker compose logs*)",
      "Bash(docker compose -f docker-compose.dev.yml up*)",
      "Bash(docker compose -f docker-compose.dev.yml restart*)",
      "Bash(docker compose -f docker-compose.dev.yml ps)",
      "Bash(docker compose -f docker-compose.dev.yml logs*)",
      "Bash(docker compose -f docker-compose.dev.yml stop*)",
      "Bash(docker exec portfolio_db mysql -uportfolio*)",
      "Bash(curl http://localhost:3000/*)",
      "Bash(curl -s http://localhost:3000/*)",
      "Bash(curl -X * http://localhost:3000/*)",
      "Bash(curl -sI http://localhost:3000/*)",
      "Bash(curl -fsS http://localhost:3000/*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git stash*)",
      "Bash(git checkout -b *)",
      "Bash(git add *)",
      "Bash(git commit*)",
      "Bash(git push -u origin *)",
      "Bash(gh pr*)",
      "Bash(gh issue*)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(rm -rf prisma/migrations*)",
      "Bash(rm -rf node_modules*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf src*)",
      "Bash(rm -rf public*)",
      "Bash(rm -rf db*)",
      "Bash(rm -rf content*)",
      "Bash(docker compose down -v*)",
      "Bash(docker compose -f docker-compose.dev.yml down -v*)",
      "Bash(docker volume rm*)",
      "Bash(*DROP DATABASE*)",
      "Bash(*DROP SCHEMA*)",
      "Bash(*TRUNCATE TABLE*)",
      "Bash(npx prisma migrate reset*)",
      "Bash(npx prisma db push --force-reset*)",
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)"
    ]
  }
}
